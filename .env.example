# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/commerce_db?schema=public"

# Server Configuration  
AUTHOR=DHVuxDev
LOCAL_DEV_APP_HOST=localhost
LOCAL_DEV_APP_PORT=3000
BUILD_MODE=dev

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-jwt-key-here
JWT_ACCESS_EXPIRES_IN=5m
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-here
JWT_REFRESH_EXPIRES_IN=7d

# Brevo Email Configuration
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@your-domain.com
BREVO_SENDER_NAME=Your Store
ADMIN_NOTIFICATION_EMAIL=admin@your-domain.com

# Website Domains
WEBSITE_DOMAIN_DEVELOPMENT=http://localhost:3000
WEBSITE_DOMAIN_PRODUCTION=https://your-production-domain.com
# Comma-separated list of allowed origins for CORS (no trailing slash)
# Example: https://your-client.vercel.app,https://your-admin.vercel.app
CORS_WHITELIST=

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/V1/users/auth/google/callback

# Facebook OAuth Configuration  
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/V1/users/auth/facebook/callback

# Client URLs
CLIENT_URL=http://localhost:3000
OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/auth/success
OAUTH_FAILURE_REDIRECT_URL=http://localhost:3000/auth/failure
