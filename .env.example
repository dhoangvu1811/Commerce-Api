# ====================================
# PostgreSQL
# ====================================
DATABASE_URL=postgresql://user:password@localhost:5432/commerce_db?schema=public
DATABASE_DIRECT_URL=postgresql://user:password@localhost:5432/commerce_db?schema=public

# ====================================
# App Configuration
# ====================================
LOCAL_DEV_APP_HOST=localhost
LOCAL_DEV_APP_PORT=8017
BUILD_MODE=dev
AUTHOR=DHVuxDev

# ====================================
# Recommender API
# ====================================
RECOMMENDER_API_URL=http://localhost:8020
# Set to true in environments where the Python recommender runs (debounced POST /recommendations/reindex after product CRUD).
RECOMMENDER_REINDEX_ENABLED=false
# Must match REINDEX_SECRET on the recommender service when that secret is set.
RECOMMENDER_REINDEX_SECRET=

# ====================================
# AI Chat RAG (n8n + ecommerce-Embeddings + Qdrant)
# ====================================
# Production webhook từ n8n sau khi import workflow (vd: http://localhost:5678/webhook/ai-chat-rag)
N8N_AI_CHAT_WEBHOOK_URL=http://localhost:5678/webhook-test/ai-chat-rag
# Timeout gọi webhook chat AI (ms). Tăng nếu workflow n8n + model trả lời chậm.
AI_CHAT_WEBHOOK_TIMEOUT_MS=120000
# Optional: gửi kèm header X-Internal-Key (khớp n8n / biến môi trường n8n)
AI_CHAT_INTERNAL_SECRET=
# Base URL dịch vụ Python embeddings (debounce POST /v1/index/reindex)
EMBEDDINGS_SERVICE_URL=http://localhost:8030
EMBEDDINGS_REINDEX_ENABLED=false
EMBEDDINGS_REINDEX_SECRET=
# URL endpoint tìm kiếm ảnh trên ecommerce-Embeddings (POST /v1/search-by-image)
EMBEDDINGS_IMAGE_SEARCH_URL=http://localhost:8030/v1/search-by-image
# Hugging Face Access Token để xác thực gọi API lên HF Space private
EMBEDDINGS_HF_TOKEN=

# ====================================
# JWT Secrets
# ====================================
JWT_ACCESS_SECRET=your-super-secret-jwt-key-here
JWT_ACCESS_EXPIRES_IN=5m
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-here
JWT_REFRESH_EXPIRES_IN=7d

# ====================================
# Cloudinary
# ====================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ====================================
# Brevo Email
# ====================================
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@your-domain.com
BREVO_SENDER_NAME=Your Store
# Legacy fallback keys for old templates/configs
ADMIN_EMAIL_ADDRESS=
ADMIN_EMAIL_NAME=
ADMIN_NOTIFICATION_EMAIL=admin@your-domain.com

# ====================================
# Website Domains
# ====================================
WEBSITE_DOMAIN_DEVELOPMENT=http://localhost:3000
WEBSITE_DOMAIN_PRODUCTION=https://your-production-domain.com

# ====================================
# CORS
# ====================================
# Comma-separated list of allowed origins (no trailing slash)
# Example: https://your-client.vercel.app,https://your-admin.vercel.app
CORS_WHITELIST=

# ====================================
# GHN Shipping
# ====================================
GHN_API_BASE_URL=https://online-gateway.ghn.vn/shiip/public-api
GHN_TOKEN=your_ghn_token
GHN_SHOP_ID=your_ghn_shop_id
GHN_FROM_DISTRICT_ID=your_from_district_id
GHN_FROM_WARD_ID=your_from_ward_code
GHN_DEFAULT_WEIGHT=500
GHN_DEFAULT_LENGTH=20
GHN_DEFAULT_WIDTH=15
GHN_DEFAULT_HEIGHT=5
GHN_FALLBACK_FEE=25000

# ====================================
# Google OAuth
# ====================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8017/V1/users/auth/google/callback

# ====================================
# Facebook OAuth
# ====================================
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:8017/V1/users/auth/facebook/callback

# ====================================
# PayPal
# ====================================
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENV=sandbox
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_CURRENCY=USD
PAYPAL_SOURCE_CURRENCY=VND
PAYPAL_VND_TO_USD_RATE=26000
